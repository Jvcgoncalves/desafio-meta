digraph G {
  rankdir=TB;
  node [shape=box, style="rounded", fontname="Arial"];
  start [label="POST /orders"];
  auth [label="Authenticated?"];
  key [label="Idempotency-Key present?"];
  hash [label="Hash normalized request"];
  existing [label="Existing idempotency key?"];
  tx [label="Start DB transaction"];
  reserve [label="Atomic stock reservation"];
  create [label="Create order + items"];
  persist [label="Persist idempotency key"];
  commit [label="Commit transaction"];
  erp [label="Process with ERP simulator"];
  authfail [label="401 AUTH_REQUIRED"];
  keyfail [label="400 IDEMPOTENCY_KEY_REQUIRED"];
  same [label="Return existing order"];
  diff [label="409 DUPLICATE_ORDER_CONFLICT"];
  stockfail [label="422 STOCK_INSUFFICIENT"];
  confirmed [label="201 CONFIRMED"];
  pending [label="202 PENDING_ERP"];
  tempfail [label="503 or FAILED_TEMPORARY"];
  start -> auth;
  auth -> authfail [label="No"];
  auth -> key [label="Yes"];
  key -> keyfail [label="No"];
  key -> hash [label="Yes"];
  hash -> existing;
  existing -> same [label="Same hash"];
  existing -> diff [label="Different hash"];
  existing -> tx [label="No"];
  tx -> reserve;
  reserve -> stockfail [label="No stock"];
  reserve -> create [label="Reserved"];
  create -> persist -> commit -> erp;
  erp -> confirmed [label="Confirmed"];
  erp -> pending [label="Slow"];
  erp -> tempfail [label="Temporary failure"];
}
